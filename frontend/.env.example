# Copy to .env (gitignored). Never commit real keys.

# WalletConnect Cloud project id (https://cloud.walletconnect.com/)
# Required for RainbowKit WalletConnect connector
VITE_WALLETCONNECT_PROJECT_ID=

# Optional RPC overrides (defaults to public endpoints)
# VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org
# VITE_BASE_RPC=https://mainnet.base.org

# Worker base URL (deployed in backend/)
VITE_API_BASE_URL=https://czero-portal-api.misterylee.workers.dev
